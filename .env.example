# Required for the Grant Automator (grant scoring + pitch generation)
OPENROUTER_API_KEY=REPLACE_ME

# Required for grant application email delivery (https://resend.com)
RESEND_API_KEY=REPLACE_ME

# Optional: live web search for grants beyond the curated database (https://exa.ai)
EXA_API_KEY=REPLACE_ME

# Database — Neon Postgres (https://neon.tech)
DATABASE_URL=REPLACE_ME

# Auth — random 32+ char secret (openssl rand -base64 32)
JWT_SECRET=REPLACE_ME

# Stripe — subscription billing (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=REPLACE_ME
STRIPE_WEBHOOK_SECRET=REPLACE_ME
STRIPE_PRO_PRICE_ID=REPLACE_ME

# App URL — used for Stripe redirect URLs
NEXT_PUBLIC_APP_URL=https://formation-wizard.vercel.app
