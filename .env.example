# Required for the Grant Automator (grant scoring + pitch generation)
OPENROUTER_API_KEY=REPLACE_ME

# Required for grant application email delivery (https://resend.com)
RESEND_API_KEY=REPLACE_ME

# Optional: live web search for grants beyond the curated database (https://exa.ai)
EXA_API_KEY=REPLACE_ME

# Database — Neon Postgres (https://neon.tech)
DATABASE_URL=REPLACE_ME

# Auth — random 32+ char secret (openssl rand -base64 32)
JWT_SECRET=REPLACE_ME

# Stripe — subscription billing (https://dashboard.stripe.com)
STRIPE_SECRET_KEY=REPLACE_ME
STRIPE_WEBHOOK_SECRET=REPLACE_ME
STRIPE_PRO_PRICE_ID=REPLACE_ME

# App URL — used for Stripe redirect URLs
NEXT_PUBLIC_APP_URL=https://formation-wizard.vercel.app

# Stripe — annual plan price ID (create in Stripe dashboard, Products → Add price)
STRIPE_PRO_ANNUAL_PRICE_ID=REPLACE_ME

# ── Delaware SOS (DECIS) ──────────────────────────────────────────────────────
# Apply at https://corp.delaware.gov — requires registered filer account
DE_SOS_API_KEY=REPLACE_ME
DE_SOS_FILER_ID=REPLACE_ME
# DE_SOS_API_URL=https://services.corp.delaware.gov/DECIS/api/v1  # override for sandbox
DE_SOS_WEBHOOK_SECRET=REPLACE_ME   # HMAC secret from DECIS portal → Webhooks

# ── Northwest Registered Agent ────────────────────────────────────────────────
# Apply at https://www.northwestregisteredagent.com/partner-program
NORTHWEST_API_KEY=REPLACE_ME
NORTHWEST_PARTNER_ID=REPLACE_ME
# NORTHWEST_API_URL=https://api.northwestregisteredagent.com/v1  # override for sandbox
NORTHWEST_WEBHOOK_SECRET=REPLACE_ME

# ── IRS EIN (SS-4) ────────────────────────────────────────────────────────────
# Requires an authorized EIN provider or IRS e-Services agreement
EIN_PROVIDER_API_KEY=REPLACE_ME
EIN_PROVIDER_API_URL=REPLACE_ME    # e.g. https://api.ein-provider.example.com/v1
EIN_PROVIDER_WEBHOOK_SECRET=REPLACE_ME

# ── Document storage (Cloudflare R2) ─────────────────────────────────────────
# Create bucket in Cloudflare dashboard → R2 → Create bucket
R2_UPLOAD_ENDPOINT=REPLACE_ME      # e.g. https://<account>.r2.cloudflarestorage.com/<bucket>
R2_API_TOKEN=REPLACE_ME

# Admin panel — protects /admin?key=... (use a long random string)
AUDIT_SECRET=REPLACE_ME
